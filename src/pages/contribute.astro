---
import Layout from '~/layouts/PageLayout.astro';
import ContributorsCanvas from '~/components/contribute/ContributorsCanvas.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const metadata = {
  title: 'Contribute',
};

// Load contributor data
interface Contributor {
  username: string;
  avatar_url: string;
  contributions: number;
  profile_url: string;
}

let contributors: Contributor[] = [];
const cachePath = join(process.cwd(), '.cache/contributors.json');
try {
  if (existsSync(cachePath)) {
    const raw = readFileSync(cachePath, 'utf-8');
    const data = JSON.parse(raw);
    contributors = data.contributors || [];
  }
} catch {
  console.warn('Failed to load contributors data, using empty list');
}

// Top contributors for leaderboard
const topContributors = contributors.slice(0, 12);

// Total stats
const totalContributions = contributors.reduce((sum, c) => sum + c.contributions, 0);
---

<Layout metadata={metadata}>
  <!-- Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-20"
  >
    <div class="absolute inset-0 opacity-30">
      <div class="absolute left-1/4 top-1/4 h-64 w-64 rounded-full bg-primary-400 blur-[100px]"></div>
      <div class="absolute right-1/4 bottom-1/3 h-64 w-64 rounded-full bg-accent-400 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="flex items-center justify-center text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          <span class="bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent">参与贡献</span
          ><span class="mx-2 text-gray-300 dark:text-gray-600">/</span><span class="text-gray-900 dark:text-white"
            >Contribute</span
          >
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          加入 iFLYTEK 开源社区，一起构建更好的 AI 生态。感谢每一位贡献者！
        </p>
      </div>

      <!-- Stats -->
      <div class="mx-auto mt-10 flex max-w-lg items-center justify-center gap-8 sm:gap-16">
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{contributors.length}</div>
          <div class="mt-1 text-sm text-gray-500">贡献者</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">
            {totalContributions.toLocaleString()}
          </div>
          <div class="mt-1 text-sm text-gray-500">总贡献</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">2</div>
          <div class="mt-1 text-sm text-gray-500">开源项目</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contributors Animation -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-2 text-center text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
        贡献者墙 / Contributors Wall
      </h2>
      <p class="mb-8 text-center text-sm text-gray-500 dark:text-gray-400">
        点击头像访问贡献者 GitHub 主页 | Click avatar to visit GitHub profile
      </p>

      {
        contributors.length > 0 ? (
          <ContributorsCanvas contributors={contributors} />
        ) : (
          <div class="flex min-h-[300px] items-center justify-center rounded-2xl border-2 border-dashed border-gray-300 dark:border-gray-700">
            <p class="text-gray-400">Contributor data loading...</p>
          </div>
        )
      }
    </div>
  </section>

  <!-- Top Contributors Leaderboard -->
  {
    topContributors.length > 0 && (
      <section class="border-t border-gray-200 bg-gray-50 py-12 dark:border-gray-800 dark:bg-gray-900/50 md:py-16">
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 text-center text-2xl font-bold text-gray-900 dark:text-white">
            贡献者排行 / Top Contributors
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {topContributors.map((c, i) => (
              <a
                href={c.profile_url}
                target="_blank"
                rel="noopener"
                class="group flex items-center gap-4 rounded-xl border border-gray-200 bg-white p-4 transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
              >
                <img
                  src={c.avatar_url}
                  alt={c.username}
                  class="h-12 w-12 rounded-full ring-2 ring-gray-200 dark:ring-gray-700"
                  loading="lazy"
                />
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    {i < 3 && (
                      <span
                        class:list={[
                          'flex h-5 w-5 items-center justify-center rounded-full text-xs font-bold text-white',
                          i === 0 ? 'bg-yellow-500' : i === 1 ? 'bg-gray-400' : 'bg-orange-400',
                        ]}
                      >
                        {i + 1}
                      </span>
                    )}
                    <h3 class="truncate font-semibold text-gray-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      {c.username}
                    </h3>
                  </div>
                  <p class="text-sm text-gray-500 dark:text-gray-400">{c.contributions} contributions</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- How to Contribute -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
        如何贡献 / How to Contribute
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-red-100 text-2xl dark:bg-red-900/50"
          >
            🐛
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">报告 Bug</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            在 GitHub Issues 中提交 Bug 报告，帮助我们发现问题、改进质量
          </p>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-yellow-100 text-2xl dark:bg-yellow-900/50"
          >
            💡
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">提出建议</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">分享你的想法和功能建议，参与项目方向讨论和 RFC</p>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 text-2xl dark:bg-blue-900/50"
          >
            🔧
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">提交代码</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Fork 项目，提交 Pull Request，修复 Bug 或开发新功能
          </p>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-2xl dark:bg-green-900/50"
          >
            📝
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">完善文档</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            改进文档、编写教程、翻译内容，让更多人能顺利使用项目
          </p>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-100 text-2xl dark:bg-purple-900/50"
          >
            🎤
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">传播分享</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Star 项目、写博客、在社区活动中分享你的使用经验</p>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
        >
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-pink-100 text-2xl dark:bg-pink-900/50"
          >
            🤝
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">社区建设</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            参与讨论、帮助新用户、组织 Meetup，共同建设开源社区
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PR Workflow -->
  <section class="border-t border-gray-200 bg-gray-50 py-12 dark:border-gray-800 dark:bg-gray-900/50 md:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-gray-900 dark:text-white">贡献流程 / PR Workflow</h2>
      <div class="grid gap-6 sm:grid-cols-4">
        {
          [
            { step: '1', title: 'Fork', desc: 'Fork 目标项目到你的 GitHub 账号' },
            { step: '2', title: 'Branch', desc: '从 main 创建功能分支' },
            { step: '3', title: 'Code', desc: '编写代码、添加测试' },
            { step: '4', title: 'PR', desc: '提交 Pull Request 等待审核' },
          ].map((item) => (
            <div class="text-center">
              <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary-600 text-lg font-bold text-white">
                {item.step}
              </div>
              <h3 class="mt-3 font-semibold text-gray-900 dark:text-white">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Community Links & Good First Issues -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2">
        <!-- Good First Issues -->
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-900 sm:p-8">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">新手任务</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">从这些适合新手的 Issue 开始你的贡献之旅</p>
          <div class="mt-6">
            <a
              href="https://github.com/search?q=org%3Aiflytek+label%3A%22good+first+issue%22+state%3Aopen&type=issues"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-primary-700"
            >
              查看 Good First Issues
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Community -->
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-900 sm:p-8">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">社区链接</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">加入我们的社区，参与讨论和交流</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://github.com/iflytek"
              target="_blank"
              rel="noopener"
              class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
            >
              GitHub
            </a>
            <a
              href="https://github.com/iflytek/community"
              target="_blank"
              rel="noopener"
              class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
            >
              Code of Conduct
            </a>
            <a
              href="https://github.com/iflytek/community/blob/main/CONTRIBUTING.md"
              target="_blank"
              rel="noopener"
              class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
            >
              Contributing Guide
            </a>
            <a
              href="https://discord.com/invite/vXzgts4fK"
              class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
            >
              Discord
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
