---
import Layout from '~/layouts/PageLayout.astro';
import ProjectCard from '~/components/projects/ProjectCard.astro';
import { getProjectsWithStats } from '~/utils/project-stats';

export const prerender = false;

const metadata = {
  title: 'Projects',
  description:
    '探索科大讯飞开源项目生态 — Explore iFLYTEK open source projects covering AI Agent, agentic workflow, developer tools and more, filterable by category and language.',
};

const projects = await getProjectsWithStats();

// Sort by stars
const sortedProjects = projects.sort((a, b) => (b.data.stars || 0) - (a.data.stars || 0));

// Extract unique categories
const categories = [...new Set(sortedProjects.map((p) => p.data.category))];

// Extract unique languages
const languages = [...new Set(sortedProjects.flatMap((p) => p.data.languages || []))].sort();

const categoryLabels: Record<string, { zh: string; en: string }> = {
  'agentic-workflow': { zh: '智能体工作流 (agentic-workflow)', en: 'agentic-workflow' },
  'agentic-automation': { zh: '智能体自动化 (agentic-automation)', en: 'agentic-automation' },
  'agent-skills': { zh: '智能体技能 (agent-skills)', en: 'agent-skills' },
  tutorial: { zh: '教程指南 (tutorial)', en: 'tutorial' },
  'agent-management': { zh: '智能体管理 (agent-management)', en: 'agent-management' },
  'agent-engine': { zh: '智能体引擎 (agent-engine)', en: 'agent-engine' },
  'memory-system': { zh: '记忆系统 (memory-system)', en: 'memory-system' },
  llm: { zh: '大语言模型 (LLM)', en: 'LLM' },
};

// Total stats
const totalStars = sortedProjects.reduce((sum, p) => sum + (p.data.stars || 0), 0);
const totalForks = sortedProjects.reduce((sum, p) => sum + (p.data.forks || 0), 0);

// URL-driven filter state so filtered views are crawlable and shareable
const { searchParams } = Astro.url;
const categoryParam = searchParams.get('category') || 'all';
const languageParam = searchParams.get('language') || 'all';
const activeCategory = categories.includes(categoryParam) ? categoryParam : 'all';
const activeLanguage = languages.includes(languageParam) ? languageParam : 'all';

const filteredProjects = sortedProjects.filter(
  (p) =>
    (activeCategory === 'all' || p.data.category === activeCategory) &&
    (activeLanguage === 'all' || (p.data.languages || []).includes(activeLanguage))
);

const buildFilterUrl = (category: string, language: string) => {
  const params = new URLSearchParams();
  if (category !== 'all') params.set('category', category);
  if (language !== 'all') params.set('language', language);
  const query = params.toString();
  return query ? `/projects?${query}` : '/projects';
};

const activeChipClass = 'bg-primary-600 text-white';
const inactiveChipClass =
  'bg-gray-100 text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700';
---

<Layout metadata={metadata}>
  <!-- Page Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-24"
  >
    <div class="absolute inset-0 opacity-30">
      <div class="absolute left-1/4 top-1/4 h-64 w-64 rounded-full bg-primary-400 blur-[100px]"></div>
      <div class="absolute right-1/4 bottom-1/4 h-64 w-64 rounded-full bg-accent-400 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="flex items-center justify-center text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          <span
            class="bg-gradient-to-r from-gradient-start to-gradient-end bg-clip-text text-transparent"
            data-i18n="projects.titleZh"
          >
            开源项目
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400" data-i18n="projects.subtitle">
          探索科大讯飞的开源项目生态，涵盖 AI Agent、开发工具等前沿领域
        </p>
      </div>

      <!-- Stats Row -->
      <div class="mx-auto mt-12 flex max-w-xl items-center justify-center gap-8 sm:gap-16">
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{sortedProjects.length}</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statProjects">开源项目</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{(totalStars / 1000).toFixed(1)}k</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statStars">GitHub Stars</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{(totalForks / 1000).toFixed(1)}k</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statForks">Forks</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Filter Bar -->
      <div class="mb-4 flex flex-wrap items-center justify-center gap-2">
        <a
          href={buildFilterUrl('all', activeLanguage)}
          class:list={[
            'rounded-full px-4 py-1.5 text-xs font-medium sm:px-5 sm:py-2 sm:text-sm',
            activeCategory === 'all' ? activeChipClass : inactiveChipClass,
          ]}
        >
          <span data-lang-zh={`全部 (${sortedProjects.length})`} data-lang-en={`All (${sortedProjects.length})`}
            >全部 ({sortedProjects.length})</span
          >
        </a>
        {
          categories.map((cat) => (
            <a
              href={buildFilterUrl(cat, activeLanguage)}
              class:list={[
                'rounded-full px-4 py-1.5 text-xs font-medium sm:px-5 sm:py-2 sm:text-sm',
                activeCategory === cat ? activeChipClass : inactiveChipClass,
              ]}
            >
              <span class="i18n-zh">{categoryLabels[cat]?.zh?.split(' ')[0] || cat}</span>
              <span class="i18n-en">{categoryLabels[cat]?.en || cat}</span>
              <span class="ml-1 text-gray-400 dark:text-gray-500">
                ({sortedProjects.filter((p) => p.data.category === cat).length})
              </span>
            </a>
          ))
        }
      </div>

      <!-- Language Filter Bar -->
      {
        languages.length > 0 && (
          <div class="mb-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href={buildFilterUrl(activeCategory, 'all')}
              class:list={[
                'rounded-full px-4 py-1.5 text-xs font-medium',
                activeLanguage === 'all' ? activeChipClass : inactiveChipClass,
              ]}
            >
              <span data-lang-zh="全部语言" data-lang-en="All Languages">
                全部语言
              </span>
            </a>
            {languages.map((lang) => (
              <a
                href={buildFilterUrl(activeCategory, lang)}
                class:list={[
                  'rounded-full px-4 py-1.5 text-xs font-medium',
                  activeLanguage === lang ? activeChipClass : inactiveChipClass,
                ]}
              >
                {lang} ({sortedProjects.filter((p) => p.data.languages?.includes(lang)).length})
              </a>
            ))}
          </div>
        )
      }

      <!-- Project Cards -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
        {
          filteredProjects.map((project) => (
            <div class="h-full">
              <ProjectCard
                name={project.data.name}
                description={project.data.description}
                descriptionEn={project.data.descriptionEn}
                repo={project.data.repo}
                homepage={project.data.homepage}
                category={project.data.category}
                tags={project.data.tags}
                languages={project.data.languages}
                stars={project.data.stars}
                forks={project.data.forks}
                license={project.data.license}
                icon={project.data.icon}
                links={project.data.links}
              />
            </div>
          ))
        }
      </div>

      {
        filteredProjects.length === 0 && (
          <div class="py-16 text-center text-gray-500 dark:text-gray-400">
            <p data-lang-zh="没有符合当前筛选条件的项目" data-lang-en="No projects match the current filters">
              没有符合当前筛选条件的项目
            </p>
            <a
              href="/projects"
              class="mt-4 inline-block font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
            >
              <span data-lang-zh="清除筛选" data-lang-en="Clear filters">
                清除筛选
              </span>
            </a>
          </div>
        )
      }

      <!-- View Landscape Link -->
      <div class="mt-16 text-center">
        <a
          href="/landscape"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-primary-200 bg-primary-50 px-8 py-4 font-medium text-primary-700 transition-all hover:border-primary-300 hover:bg-primary-100 dark:border-primary-800 dark:bg-primary-950 dark:text-primary-300 dark:hover:bg-primary-900"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
            ></path>
          </svg>
          <span data-i18n="projects.viewLandscape">查看全景图</span>
          <span>→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
