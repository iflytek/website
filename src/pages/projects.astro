---
import Layout from '~/layouts/PageLayout.astro';
import ProjectCard from '~/components/projects/ProjectCard.astro';
import { getProjectsWithStats } from '~/utils/project-stats';

export const prerender = false;

const metadata = {
  title: 'Projects',
};

const projects = await getProjectsWithStats();

// Sort by stars
const sortedProjects = projects.sort((a, b) => (b.data.stars || 0) - (a.data.stars || 0));

// Extract unique categories
const categories = [...new Set(sortedProjects.map((p) => p.data.category))];

// Extract unique languages
const languages = [...new Set(sortedProjects.flatMap((p) => p.data.languages || []))].sort();

const categoryLabels: Record<string, { zh: string; en: string }> = {
  'ai-platform': { zh: 'AI 平台', en: 'AI Platform' },
  'developer-tools': { zh: '开发者工具', en: 'Developer Tools' },
  'rpa-automation': { zh: 'RPA & 自动化', en: 'RPA & Automation' },
  'ai-skills': { zh: 'AI 技能', en: 'AI Skills' },
  tutorials: { zh: '教程', en: 'Tutorials' },
  'nlp-speech': { zh: 'NLP & 语音', en: 'NLP & Speech' },
  infrastructure: { zh: '基础设施', en: 'Infrastructure' },
};

// Total stats
const totalStars = sortedProjects.reduce((sum, p) => sum + (p.data.stars || 0), 0);
const totalForks = sortedProjects.reduce((sum, p) => sum + (p.data.forks || 0), 0);
---

<Layout metadata={metadata}>
  <!-- Page Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-24"
  >
    <div class="absolute inset-0 opacity-30">
      <div class="absolute left-1/4 top-1/4 h-64 w-64 rounded-full bg-primary-400 blur-[100px]"></div>
      <div class="absolute right-1/4 bottom-1/4 h-64 w-64 rounded-full bg-accent-400 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="flex items-center justify-center text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          <span
            class="bg-gradient-to-r from-gradient-start to-gradient-end bg-clip-text text-transparent"
            data-i18n="projects.titleZh"
          >
            开源项目
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400" data-i18n="projects.subtitle">
          探索科大讯飞的开源项目生态，涵盖 AI Agent、开发工具等前沿领域
        </p>
      </div>

      <!-- Stats Row -->
      <div class="mx-auto mt-12 flex max-w-xl items-center justify-center gap-8 sm:gap-16">
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{sortedProjects.length}</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statProjects">开源项目</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{(totalStars / 1000).toFixed(1)}k</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statStars">GitHub Stars</div>
        </div>
        <div class="h-10 w-px bg-gray-200 dark:bg-gray-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{(totalForks / 1000).toFixed(1)}k</div>
          <div class="mt-1 text-sm text-gray-500" data-i18n="projects.statForks">Forks</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Filter Bar -->
      <div class="mb-4 flex flex-wrap items-center justify-center gap-3">
        <button
          class="category-btn rounded-full bg-primary-600 px-5 py-2 text-sm font-medium text-white"
          data-category="all"
        >
          <span data-lang-zh="全部 ({sortedProjects.length})" data-lang-en="All ({sortedProjects.length})"
            >全部 ({sortedProjects.length})</span
          >
        </button>
        {
          categories.map((cat) => (
            <button
              class="category-btn rounded-full bg-gray-100 px-5 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
              data-category={cat}
            >
              <span
                data-lang-zh={`${categoryLabels[cat]?.zh || cat} (${sortedProjects.filter((p) => p.data.category === cat).length})`}
                data-lang-en={`${categoryLabels[cat]?.en || cat} (${sortedProjects.filter((p) => p.data.category === cat).length})`}
              >
                {categoryLabels[cat]?.zh || cat} ({sortedProjects.filter((p) => p.data.category === cat).length})
              </span>
            </button>
          ))
        }
      </div>

      <!-- Language Filter Bar -->
      {
        languages.length > 0 && (
          <div class="mb-8 flex flex-wrap items-center justify-center gap-3">
            <button
              class="lang-btn rounded-full bg-primary-600 px-4 py-1.5 text-xs font-medium text-white"
              data-language="all"
            >
              <span data-lang-zh="全部语言" data-lang-en="All Languages">
                全部语言
              </span>
            </button>
            {languages.map((lang) => (
              <button
                class="lang-btn rounded-full bg-gray-100 px-4 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                data-language={lang}
              >
                {lang} ({sortedProjects.filter((p) => p.data.languages?.includes(lang)).length})
              </button>
            ))}
          </div>
        )
      }

      <!-- Project Cards -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
        {
          sortedProjects.map((project) => (
            <div
              class="project-card"
              data-category={project.data.category}
              data-languages={(project.data.languages || []).join(',')}
            >
              <ProjectCard
                name={project.data.name}
                description={project.data.description}
                repo={project.data.repo}
                homepage={project.data.homepage}
                category={project.data.category}
                tags={project.data.tags}
                languages={project.data.languages}
                stars={project.data.stars}
                forks={project.data.forks}
                license={project.data.license}
              />
            </div>
          ))
        }
      </div>

      <!-- View Landscape Link -->
      <div class="mt-16 text-center">
        <a
          href="/landscape"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-primary-200 bg-primary-50 px-8 py-4 font-medium text-primary-700 transition-all hover:border-primary-300 hover:bg-primary-100 dark:border-primary-800 dark:bg-primary-950 dark:text-primary-300 dark:hover:bg-primary-900"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
            ></path>
          </svg>
          <span data-i18n="projects.viewLandscape">查看全景图</span>
          <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Filter Script -->
  <script is:inline>
    (function () {
      let activeCategory = 'all';
      let activeLanguage = 'all';

      function applyFilters() {
        const cards = document.querySelectorAll('.project-card');
        cards.forEach((card) => {
          const cardCategory = card.dataset.category;
          const cardLanguages = (card.dataset.languages || '').split(',').filter(Boolean);

          const matchesCategory = activeCategory === 'all' || cardCategory === activeCategory;
          const matchesLanguage = activeLanguage === 'all' || cardLanguages.includes(activeLanguage);

          card.style.display = matchesCategory && matchesLanguage ? '' : 'none';
        });
      }

      function setupButtonGroup(selector, callback) {
        const buttons = document.querySelectorAll(selector);
        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            buttons.forEach((b) => {
              b.classList.remove('bg-primary-600', 'text-white');
              b.classList.add('bg-gray-100', 'text-gray-700', 'dark:bg-gray-800', 'dark:text-gray-300');
            });
            btn.classList.add('bg-primary-600', 'text-white');
            btn.classList.remove('bg-gray-100', 'text-gray-700', 'dark:bg-gray-800', 'dark:text-gray-300');
            callback(btn);
            applyFilters();
          });
        });
      }

      function setupFilters() {
        setupButtonGroup('.category-btn', (btn) => {
          activeCategory = btn.dataset.category || 'all';
        });
        setupButtonGroup('.lang-btn', (btn) => {
          activeLanguage = btn.dataset.language || 'all';
        });
      }

      if (document.readyState !== 'loading') {
        setupFilters();
      } else {
        document.addEventListener('DOMContentLoaded', setupFilters);
      }
    })();
  </script>
</Layout>
