---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Events',
};

interface Event {
  title: string;
  titleZh: string;
  date: string;
  type: 'conference' | 'meetup' | 'hackathon' | 'workshop' | 'webinar';
  status?: 'upcoming' | 'ongoing' | 'past';
  description: string;
  location: string;
  link?: string;
}

const events: Event[] = [
  {
    title: '2nd AI Innovation Exchange Conference · Tianjin',
    titleZh: '智汇津城·破界新生——第 2 届人工智能创新发展交流会',
    date: '2026-07-11',
    type: 'meetup',
    description: '技术分享：企业级 Agentic AI 智能体应用架构与知识工程实践',
    location: 'Tianjin, China',
    link: 'https://mp.weixin.qq.com/s/N7qphWxzAMByttJ9OcxWBQ',
  },
  {
    title: 'AI Agent Industry Practice @ AtomGit & Ascend Meetup · Shanghai',
    titleZh: '智驱迭代·昇腾赋能——AI Agent 行业实践',
    date: '2026-06-27',
    type: 'meetup',
    description: '技术分享：基于 Astron-Agent 的智能代理架构与知识工程实践',
    location: 'Shanghai, China',
    link: 'https://mp.weixin.qq.com/s/ZgygUsKPZQGeL8cB1x2D_g',
  },
  {
    title: 'Astron Hackathon @ 2025 iFLYTEK Global 1024 Developer Festival',
    titleZh: 'Astron 黑客松 @ 2025 讯飞全球 1024 开发者节',
    date: '2025-10-24',
    type: 'hackathon',
    description: '年度 AI 开发者盛会，基于 Astron Agent 平台的创新挑战赛',
    location: 'Hefei, China',
    link: 'https://luma.com/9zmbc6xb',
  },
  {
    title: 'Astron Agent Zhengzhou Meetup',
    titleZh: 'Astron Agent 郑州 Meetup',
    date: '2025-09-20',
    type: 'meetup',
    description: '社区线下交流，分享 Astron Agent 最佳实践与企业落地案例',
    location: 'Zhengzhou, China',
    link: 'https://github.com/iflytek/astron-agent/discussions/672',
  },
  {
    title: 'Astron on Campus @ Zhejiang University of Finance and Economics',
    titleZh: 'Astron 进校园 @ 浙江财经大学',
    date: '2025-06-15',
    type: 'workshop',
    description: '走进校园，为高校学子介绍 AI Agent 开发技术与开源生态',
    location: 'Hangzhou, China',
    link: 'https://mp.weixin.qq.com/s/oim_Z0ckgpFwf5jOskoJuA',
  },
  {
    title: 'Astron Agent & RPA · Qingdao Meetup',
    titleZh: 'Astron Agent & RPA · 青岛 Meetup',
    date: '2025-05-18',
    type: 'meetup',
    description: '聚焦 Agentic AI 与 RPA 的融合，探讨企业自动化新范式',
    location: 'Qingdao, China',
    link: 'https://github.com/iflytek/astron-agent/discussions/740',
  },
  {
    title: 'Astron Training Camp · Cohort #1',
    titleZh: 'Astron 训练营 · 第 1 期',
    date: '2025-04-10',
    type: 'workshop',
    description: '系统化的 Astron Agent 开发培训，从入门到实战',
    location: 'Online',
    link: 'https://www.aidaxue.com/astronCamp',
  },
  {
    title: 'Astron Talk @ Chongqing Mini Tech Fest',
    titleZh: 'Astron 分享 @ 重庆 Mini Tech Fest',
    date: '2025-03-22',
    type: 'meetup',
    description: '技术分享：AI Agent 在企业中的落地实践',
    location: 'Chongqing, China',
  },
  {
    title: 'Astron Agent @ MWC Barcelona 2026',
    titleZh: 'Astron Agent 亮相 MWC Barcelona 2026',
    date: '2026-02-25',
    type: 'conference',
    description: '在世界移动通信大会上展示企业级 AI Agent 工作流平台',
    location: 'Barcelona, Spain',
    link: 'https://www.iflytek.com/en/news-events/mwc2026.html',
  },
  {
    title: 'Astron Agent & RPA · Hefei Meetup',
    titleZh: 'Astron Agent & RPA · 合肥 Meetup',
    date: '2026-03-15',
    type: 'meetup',
    description: '社区线下交流，聚焦 RPA 与 Agent 的深度集成',
    location: 'Hefei, China',
  },
  {
    title: 'Astron Industrial Intelligence Hackathon',
    titleZh: 'Astron 工业智能黑客松',
    date: '2026-05-20',
    type: 'hackathon',
    description: '面向工业场景的 AI Agent 创新挑战赛',
    location: 'Online + Hefei',
    link: 'https://awesome-astron-workflow.dev/activities/astron-industrial-intelligence-hackathon',
  },
];

// Auto-determine status based on event date vs current date
const now = new Date();
const todayStr = now.toISOString().split('T')[0];
events.forEach((event) => {
  event.status = event.date === todayStr ? 'ongoing' : event.date > todayStr ? 'upcoming' : 'past';
});

// Sort by date descending
events.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const typeLabels: Record<string, string> = {
  conference: 'Conference',
  meetup: 'Meetup',
  hackathon: 'Hackathon',
  workshop: 'Workshop',
  webinar: 'Webinar',
};

const typeColors: Record<string, string> = {
  conference: 'bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300',
  meetup: 'bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300',
  hackathon: 'bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300',
  workshop: 'bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300',
  webinar: 'bg-pink-100 text-pink-800 dark:bg-pink-900/50 dark:text-pink-300',
};

// Get unique types for filter
const eventTypes = [...new Set(events.map((e) => e.type))];

// Blog posts for news section
const posts = await getCollection('post');
const newsPosts = posts
  .filter((p) => p.data.category === 'news')
  .sort(
    (a, b) =>
      new Date(b.data.publishDate || Date.now()).getTime() - new Date(a.data.publishDate || Date.now()).getTime()
  );
---

<Layout metadata={metadata}>
  <!-- Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-20"
  >
    <div class="absolute inset-0 opacity-30">
      <div class="absolute left-1/3 top-1/3 h-48 w-48 rounded-full bg-primary-400 blur-[80px]"></div>
      <div class="absolute right-1/3 bottom-1/3 h-48 w-48 rounded-full bg-accent-400 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="flex items-center justify-center text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          <span
            class="bg-gradient-to-r from-gradient-start to-gradient-end bg-clip-text text-transparent"
            data-i18n="events.titleZh">社区活动</span
          >
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400" data-i18n="events.subtitle">
          参与科大讯飞开源社区活动 — Meetup、Hackathon、Workshop，与开发者面对面交流
        </p>
      </div>
    </div>
  </section>

  <!-- Events Timeline -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <!-- Filter Tabs -->
      <div class="mb-10 flex flex-wrap items-center justify-center gap-3">
        <button
          class="event-filter-btn rounded-full bg-primary-600 px-5 py-2 text-sm font-medium text-white"
          data-type="all"
        >
          <span data-lang-zh={`全部 (${events.length})`} data-lang-en={`All (${events.length})`}
            >全部 ({events.length})</span
          >
        </button>
        {
          eventTypes.map((type) => (
            <button
              class="event-filter-btn rounded-full bg-gray-100 px-5 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
              data-type={type}
            >
              {typeLabels[type]} ({events.filter((e) => e.type === type).length})
            </button>
          ))
        }
      </div>

      <!-- Timeline -->
      <div class="space-y-1">
        {
          events.map((event, index) => (
            <div class="event-item relative flex gap-4 sm:gap-8" data-type={event.type}>
              {/* Timeline line & dot */}
              <div class="flex flex-col items-center">
                <div class="relative z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center">
                  <div
                    class:list={[
                      'h-3.5 w-3.5 rounded-full ring-4 ring-white dark:ring-gray-950',
                      event.status === 'upcoming'
                        ? 'bg-green-500'
                        : event.status === 'ongoing'
                          ? 'bg-yellow-500 animate-pulse'
                          : 'bg-gray-300 dark:bg-gray-600',
                    ]}
                  />
                </div>
                {index < events.length - 1 && <div class="w-px flex-1 bg-gray-200 dark:bg-gray-800" />}
              </div>

              {/* Event Card */}
              <div class="mb-8 flex-1 rounded-xl border border-gray-200 bg-white p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-primary-800 sm:p-6">
                <div class="flex flex-wrap items-start justify-between gap-2">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium', typeColors[event.type]]}>
                      {typeLabels[event.type]}
                    </span>
                    <span
                      class:list={[
                        'rounded-full px-2.5 py-0.5 text-xs font-medium',
                        event.status === 'upcoming'
                          ? 'bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300'
                          : event.status === 'ongoing'
                            ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-300'
                            : 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400',
                      ]}
                    >
                      {event.status === 'upcoming' ? (
                        <span data-i18n="events.upcoming">即将举办</span>
                      ) : event.status === 'ongoing' ? (
                        <span data-i18n="events.ongoing">进行中</span>
                      ) : (
                        <span data-i18n="events.past">已结束</span>
                      )}
                    </span>
                  </div>
                  <time class="text-sm font-medium text-gray-500 dark:text-gray-400">{event.date}</time>
                </div>

                <h3 class="mt-3 text-lg font-bold text-gray-900 dark:text-white">
                  {event.link ? (
                    <a
                      href={event.link}
                      target="_blank"
                      rel="noopener"
                      class="hover:text-primary-600 dark:hover:text-primary-400"
                    >
                      <span data-lang-zh={event.titleZh} data-lang-en={event.title}>
                        {event.titleZh}
                      </span>
                    </a>
                  ) : (
                    <span data-lang-zh={event.titleZh} data-lang-en={event.title}>
                      {event.titleZh}
                    </span>
                  )}
                </h3>
                <p
                  class="mt-1 text-sm text-gray-500 dark:text-gray-500"
                  data-lang-zh={event.titleZh}
                  data-lang-en={event.title}
                >
                  {event.title}
                </p>
                <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">{event.description}</p>

                <div class="mt-4 flex items-center justify-between">
                  <span class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                    {event.location}
                  </span>
                  {event.link && (
                    <a
                      href={event.link}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                    >
                      <span data-i18n="events.viewDetails">详情</span>
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- News Section -->
  {
    newsPosts.length > 0 && (
      <section class="border-t border-gray-200 bg-gray-50 py-12 dark:border-gray-800 dark:bg-gray-900/50 md:py-16">
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 text-center text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
            <span data-i18n="events.latestNews">最新动态</span>
          </h2>
          <div class="grid gap-6 sm:grid-cols-2">
            {newsPosts.slice(0, 4).map((post) => (
              <a
                href={`/blog/${post.id.replace('.md', '').replace('.mdx', '')}`}
                class="group rounded-xl border border-gray-200 bg-white p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-primary-800"
              >
                <span class="inline-block rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/50 dark:text-blue-300">
                  News
                </span>
                <h3 class="mt-3 font-semibold text-gray-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                  {post.data.title}
                </h3>
                {post.data.excerpt && (
                  <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">{post.data.excerpt}</p>
                )}
                <time class="mt-3 block text-xs text-gray-400">
                  {post.data.publishDate ? new Date(post.data.publishDate).toLocaleDateString('zh-CN') : ''}
                </time>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Filter Script -->
  <script is:inline>
    (function () {
      function setupFilters() {
        const buttons = document.querySelectorAll('.event-filter-btn');
        const items = document.querySelectorAll('.event-item');

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const type = btn.dataset.type;

            // Update button styles
            buttons.forEach((b) => {
              b.classList.remove('bg-primary-600', 'text-white');
              b.classList.add('bg-gray-100', 'text-gray-700', 'dark:bg-gray-800', 'dark:text-gray-300');
            });
            btn.classList.add('bg-primary-600', 'text-white');
            btn.classList.remove('bg-gray-100', 'text-gray-700', 'dark:bg-gray-800', 'dark:text-gray-300');

            // Filter items
            items.forEach((item) => {
              const itemType = item.dataset.type;
              if (type === 'all' || itemType === type) {
                item.style.display = '';
              } else {
                item.style.display = 'none';
              }
            });
          });
        });
      }

      if (document.readyState !== 'loading') {
        setupFilters();
      } else {
        document.addEventListener('DOMContentLoaded', setupFilters);
      }
    })();
  </script>
</Layout>
