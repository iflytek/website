---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getCollection } from 'astro:content';

const metadata = {
  title: 'iFLYTEK Open Source — AI Agent, Developer Tools & More',
  ignoreTitleTemplate: true,
};

const projects = await getCollection('project');
const totalStars = projects.reduce((sum, p) => sum + (p.data.stars || 0), 0);
const totalForks = projects.reduce((sum, p) => sum + (p.data.forks || 0), 0);
const starDisplay = totalStars >= 1000 ? (totalStars / 1000).toFixed(1) + 'K' : totalStars.toString();
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: '探索项目',
        href: '/projects',
        icon: 'tabler:code',
      },
      {
        text: '参与贡献',
        href: '/contribute',
      },
    ]}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-primary-400">iFLYTEK</span>
      Open Source
    </Fragment>

    <Fragment slot="subtitle">
      探索科大讯飞的开源世界 — 涵盖 AI 大模型、自然语言处理、语音识别等前沿技术，共建智能未来。
    </Fragment>
  </Hero>

  <!-- Stats Section -->
  <Stats
    tagline="开源数据"
    title="iFLYTEK 开源生态"
    stats={[
      {
        title: '开源项目',
        amount: projects.length.toString(),
        icon: 'tabler:code',
      },
      {
        title: 'GitHub Stars',
        amount: starDisplay,
        icon: 'tabler:star',
      },
      {
        title: 'Forks',
        amount: totalForks >= 1000 ? (totalForks / 1000).toFixed(1) + 'K' : totalForks.toString(),
        icon: 'tabler:git-fork',
      },
      {
        title: '开源协议',
        amount: 'Apache 2.0',
        icon: 'tabler:license',
      },
    ]}
  />

  <!-- Featured Areas -->
  <Features
    id="explore"
    tagline="探索"
    title="发现开源的力量"
    subtitle="从 AI 大模型到开发者工具，iFLYTEK 开源生态覆盖多个技术领域"
    items={[
      {
        title: '开源项目',
        description: '涵盖 AI、NLP、语音识别、开发者工具等多个领域的开源项目，提供完整的文档和示例。',
        icon: 'tabler:box',
      },
      {
        title: '全景图',
        description: 'CNCF 风格的开源生态全景图，一目了然地查看所有 iFLYTEK 开源项目及分类。',
        icon: 'tabler:map',
      },
      {
        title: '技术博客',
        description: '深入的技术文章、教程和架构分享，帮助你更好地理解和使用开源项目。',
        icon: 'tabler:article',
      },
      {
        title: '社区活动',
        description: 'Meetup、Hackathon、Conference 等丰富多彩的社区活动，与开发者面对面交流。',
        icon: 'tabler:calendar-event',
      },
      {
        title: '参与贡献',
        description: '无论你是新手还是资深开发者，都可以找到适合自己的贡献方式。',
        icon: 'tabler:git-pull-request',
      },
      {
        title: '开源许可',
        description: '所有项目均采用宽松的开源协议，鼓励商业使用和技术创新。',
        icon: 'tabler:license',
      },
    ]}
  />

  <!-- Latest Blog Posts -->
  <BlogLatestPosts title="技术博客与新闻" />

  <!-- Call to Action -->
  <CallToAction
    title="加入 iFLYTEK 开源社区"
    subtitle="与我们一起构建更好的 AI 开源生态"
    actions={[
      {
        variant: 'primary',
        text: '在 GitHub 上关注我们',
        href: 'https://github.com/iflytek',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: '加入 Discord',
        href: 'https://discord.com/invite/vXzgts4fK',
        icon: 'tabler:brand-discord',
      },
    ]}
  />
</Layout>
