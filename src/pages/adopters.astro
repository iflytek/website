---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Adopters',
};

const adopters = await getCollection('adopter');
const reversedAdopters = [...adopters].reverse();
const adopterJSON = JSON.stringify(
  adopters.map((a) => ({
    slug: a.id,
    name: a.data.name,
    nameEn: a.data.nameEn || a.data.name,
    logo: a.data.logo,
    subtitle: a.data.subtitle,
    subtitleEn: a.data.subtitleEn || a.data.subtitle,
    tags: a.data.tags || [],
    tagsEn: a.data.tagsEn || a.data.tags || [],
    scenario: a.data.scenario,
    scenarioEn: a.data.scenarioEn || a.data.scenario,
    delivery: a.data.delivery,
    deliveryEn: a.data.deliveryEn || a.data.delivery,
    outcome: a.data.outcome,
    outcomeEn: a.data.outcomeEn || a.data.outcome,
  }))
);
---

<Layout metadata={metadata}>
  <!-- Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-20"
  >
    <div class="absolute inset-0 opacity-30">
      <div class="absolute left-1/3 top-1/3 h-48 w-48 rounded-full bg-primary-400 blur-[80px]"></div>
      <div class="absolute right-1/3 bottom-1/3 h-48 w-48 rounded-full bg-accent-400 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="flex items-center justify-center text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          <span
            class="bg-gradient-to-r from-gradient-start to-gradient-end bg-clip-text text-transparent"
            data-lang-zh="用户案例"
            data-lang-en="Adopters">用户案例</span
          >
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400" data-i18n="adopters.subtitle">
          探索 Astron 开源生态的用户案例，了解各行业如何利用 AI Agent 平台实现业务创新
        </p>
      </div>
    </div>
  </section>

  <!-- Adopters Marquee - Row 1 (left scroll) -->
  <section class="py-8 md:py-12">
    <div class="overflow-hidden">
      <div class="marquee-left flex gap-6">
        {
          adopters.map((adopter) => {
            const { name, nameEn, logo, subtitle, subtitleEn, tags, tagsEn, scenario, scenarioEn } = adopter.data;
            return (
              <div
                data-adopter-id={adopter.id}
                class="adopters-card cursor-pointer flex-shrink-0 w-[22rem] rounded-2xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-blue-700"
              >
                <div class="flex items-center gap-4">
                  <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white p-2 shadow-inner">
                    <img src={logo} alt={name} class="h-full w-full object-contain" loading="lazy" />
                  </div>
                  <div>
                    <h3
                      class="text-lg font-bold text-gray-900 dark:text-white"
                      data-lang-zh={name}
                      data-lang-en={nameEn || name}
                    >
                      {name}
                    </h3>
                    <p
                      class="text-sm text-gray-500 dark:text-gray-400"
                      data-lang-zh={subtitle}
                      data-lang-en={subtitleEn || subtitle}
                    >
                      {subtitle}
                    </p>
                  </div>
                </div>
                {tags && tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((tag, i) => (
                      <span
                        class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300"
                        data-lang-zh={tag}
                        data-lang-en={tagsEn?.[i] || tag}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <p
                  class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400"
                  data-lang-zh={scenario}
                  data-lang-en={scenarioEn || scenario}
                >
                  {scenario}
                </p>
              </div>
            );
          })
        }
        {
          adopters.map((adopter) => {
            const { name, nameEn, logo, subtitle, subtitleEn, tags, tagsEn, scenario, scenarioEn } = adopter.data;
            return (
              <div
                data-adopter-id={adopter.id}
                class="adopters-card cursor-pointer flex-shrink-0 w-[22rem] rounded-2xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-blue-700"
              >
                <div class="flex items-center gap-4">
                  <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white p-2 shadow-inner">
                    <img src={logo} alt={name} class="h-full w-full object-contain" loading="lazy" />
                  </div>
                  <div>
                    <h3
                      class="text-lg font-bold text-gray-900 dark:text-white"
                      data-lang-zh={name}
                      data-lang-en={nameEn || name}
                    >
                      {name}
                    </h3>
                    <p
                      class="text-sm text-gray-500 dark:text-gray-400"
                      data-lang-zh={subtitle}
                      data-lang-en={subtitleEn || subtitle}
                    >
                      {subtitle}
                    </p>
                  </div>
                </div>
                {tags && tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((tag, i) => (
                      <span
                        class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300"
                        data-lang-zh={tag}
                        data-lang-en={tagsEn?.[i] || tag}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <p
                  class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400"
                  data-lang-zh={scenario}
                  data-lang-en={scenarioEn || scenario}
                >
                  {scenario}
                </p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Adopters Marquee - Row 2 (right scroll) -->
  <section class="pb-12 md:pb-16">
    <div class="overflow-hidden">
      <div class="marquee-right flex gap-6">
        {
          reversedAdopters.map((adopter) => {
            const { name, nameEn, logo, subtitle, subtitleEn, tags, tagsEn, scenario, scenarioEn } = adopter.data;
            return (
              <div
                data-adopter-id={adopter.id}
                class="adopters-card cursor-pointer flex-shrink-0 w-[22rem] rounded-2xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-blue-700"
              >
                <div class="flex items-center gap-4">
                  <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white p-2 shadow-inner">
                    <img src={logo} alt={name} class="h-full w-full object-contain" loading="lazy" />
                  </div>
                  <div>
                    <h3
                      class="text-lg font-bold text-gray-900 dark:text-white"
                      data-lang-zh={name}
                      data-lang-en={nameEn || name}
                    >
                      {name}
                    </h3>
                    <p
                      class="text-sm text-gray-500 dark:text-gray-400"
                      data-lang-zh={subtitle}
                      data-lang-en={subtitleEn || subtitle}
                    >
                      {subtitle}
                    </p>
                  </div>
                </div>
                {tags && tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((tag, i) => (
                      <span
                        class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300"
                        data-lang-zh={tag}
                        data-lang-en={tagsEn?.[i] || tag}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <p
                  class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400"
                  data-lang-zh={scenario}
                  data-lang-en={scenarioEn || scenario}
                >
                  {scenario}
                </p>
              </div>
            );
          })
        }
        {
          reversedAdopters.map((adopter) => {
            const { name, nameEn, logo, subtitle, subtitleEn, tags, tagsEn, scenario, scenarioEn } = adopter.data;
            return (
              <div
                data-adopter-id={adopter.id}
                class="adopters-card cursor-pointer flex-shrink-0 w-[22rem] rounded-2xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900 dark:hover:border-blue-700"
              >
                <div class="flex items-center gap-4">
                  <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white p-2 shadow-inner">
                    <img src={logo} alt={name} class="h-full w-full object-contain" loading="lazy" />
                  </div>
                  <div>
                    <h3
                      class="text-lg font-bold text-gray-900 dark:text-white"
                      data-lang-zh={name}
                      data-lang-en={nameEn || name}
                    >
                      {name}
                    </h3>
                    <p
                      class="text-sm text-gray-500 dark:text-gray-400"
                      data-lang-zh={subtitle}
                      data-lang-en={subtitleEn || subtitle}
                    >
                      {subtitle}
                    </p>
                  </div>
                </div>
                {tags && tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((tag, i) => (
                      <span
                        class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300"
                        data-lang-zh={tag}
                        data-lang-en={tagsEn?.[i] || tag}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <p
                  class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400"
                  data-lang-zh={scenario}
                  data-lang-en={scenarioEn || scenario}
                >
                  {scenario}
                </p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="pb-8 md:pb-12">
    <p class="text-center text-sm text-gray-600 dark:text-gray-400" data-i18n="adopters.disclaimer">
      * 以上案例已获用户授权同意展示
    </p>
  </section>

  <!-- Adopter detail modal -->
  <div id="adopter-modal" class="fixed inset-0 z-50 hidden items-end justify-center p-0 md:items-center md:p-6">
    <!-- Overlay -->
    <div
      class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-200 opacity-0"
      data-modal-close
    >
    </div>
    <!-- Modal card -->
    <div
      class="modal-card relative w-full max-w-2xl overflow-y-auto rounded-t-3xl rounded-b-none bg-white/90 backdrop-blur-xl shadow-2xl border border-gray-200/50 transition-all duration-200 opacity-0 scale-95 max-h-[90vh] dark:bg-gray-900/90 dark:border-gray-700/50 md:rounded-3xl md:max-h-[85vh]"
    >
      <!-- Close button -->
      <button
        class="absolute right-4 top-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-gray-200/60 text-gray-500 transition hover:bg-gray-300/80 hover:text-gray-700 dark:bg-gray-700/60 dark:text-gray-400 dark:hover:bg-gray-600/80 dark:hover:text-gray-200"
        data-modal-close
        aria-label="Close"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg
        >
      </button>

      <!-- Content filled by JS -->
      <div id="modal-content"></div>
    </div>
  </div>

  <script is:inline define:vars={{ adopterJSON }}>
    (function () {
      const PREFIX = 'adopter-';
      const modal = document.getElementById('adopter-modal');
      const contentEl = document.getElementById('modal-content');
      const card = modal ? modal.querySelector('.modal-card') : null;
      const overlay = modal ? modal.querySelector('[data-modal-close]') : null;
      let adopters = [];

      try {
        adopters = JSON.parse(adopterJSON);
      } catch {
        // ignore parse errors
      }

      function findAdopter(slug) {
        return adopters.find((a) => a.slug === slug);
      }

      function escapeHtml(str) {
        return (str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function getLang() {
        return document.documentElement.classList.contains('lang-en') ? 'en' : 'zh';
      }

      function t(key) {
        const map = {
          'adopters.modal.scenario': ['业务场景', 'Scenario'],
          'adopters.modal.delivery': ['落地方式', 'Delivery'],
          'adopters.modal.outcome': ['应用成果', 'Outcome'],
        };
        const pair = map[key] || [key, key];
        return getLang() === 'en' ? pair[1] : pair[0];
      }

      function buildModalHtml(a) {
        const isEn = getLang() === 'en';
        const name = isEn ? a.nameEn || a.name : a.name;
        const subtitle = isEn ? a.subtitleEn || a.subtitle : a.subtitle;
        const scenario = isEn ? a.scenarioEn || a.scenario : a.scenario;
        const delivery = isEn ? a.deliveryEn || a.delivery : a.delivery;
        const outcome = isEn ? a.outcomeEn || a.outcome : a.outcome;
        const labelScenario = t('adopters.modal.scenario');
        const labelDelivery = t('adopters.modal.delivery');
        const labelOutcome = t('adopters.modal.outcome');

        const activeTags = isEn ? a.tagsEn || a.tags || [] : a.tags || [];
        const tagsHtml = activeTags
          .map(function (tag) {
            return (
              '<span class="inline-flex items-center rounded-md bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">' +
              escapeHtml(tag) +
              '</span>'
            );
          })
          .join('');

        return (
          '<div class="p-6 md:p-8">' +
          '<div class="flex items-start gap-5 mb-6">' +
          '<div class="flex h-20 w-20 flex-shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white p-2 shadow-inner dark:bg-gray-800">' +
          '<img src="' +
          escapeHtml(a.logo) +
          '" alt="' +
          escapeHtml(name) +
          '" class="h-full w-full object-contain" loading="lazy" />' +
          '</div>' +
          '<div class="flex-1 min-w-0 pt-1">' +
          '<h2 class="text-2xl font-bold text-gray-900 dark:text-white truncate">' +
          escapeHtml(name) +
          '</h2>' +
          '<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">' +
          escapeHtml(subtitle) +
          '</p>' +
          (tagsHtml ? '<div class="mt-3 flex flex-wrap gap-1.5">' + tagsHtml + '</div>' : '') +
          '</div>' +
          '</div>' +
          '<div class="border-t border-gray-200/60 dark:border-gray-700/60 my-2"></div>' +
          '<div class="mt-6 space-y-0">' +
          '<div class="mb-6"><div class="flex items-center gap-2 mb-2"><div class="h-4 w-1 rounded-full bg-gradient-to-b from-blue-500 to-purple-500"></div><span class="text-sm font-semibold text-gray-500 dark:text-gray-400">' +
          escapeHtml(labelScenario) +
          '</span></div><p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300 pl-3">' +
          escapeHtml(scenario) +
          '</p></div>' +
          '<div class="mb-6"><div class="flex items-center gap-2 mb-2"><div class="h-4 w-1 rounded-full bg-gradient-to-b from-purple-500 to-pink-500"></div><span class="text-sm font-semibold text-gray-500 dark:text-gray-400">' +
          escapeHtml(labelDelivery) +
          '</span></div><p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300 pl-3">' +
          escapeHtml(delivery) +
          '</p></div>' +
          '<div class="mb-2"><div class="flex items-center gap-2 mb-2"><div class="h-4 w-1 rounded-full bg-gradient-to-b from-pink-500 to-orange-400"></div><span class="text-sm font-semibold text-gray-500 dark:text-gray-400">' +
          escapeHtml(labelOutcome) +
          '</span></div><p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300 pl-3">' +
          escapeHtml(outcome) +
          '</p></div>' +
          '</div>' +
          '</div>'
        );
      }

      function openModal(slug) {
        const a = findAdopter(slug);
        if (!a) return;
        contentEl.innerHTML = buildModalHtml(a);
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(function () {
          if (card) {
            card.classList.remove('opacity-0', 'scale-95');
            card.classList.add('opacity-100', 'scale-100');
          }
          if (overlay) {
            overlay.classList.remove('opacity-0');
            overlay.classList.add('opacity-100');
          }
        });
      }

      function closeModal() {
        if (card) {
          card.classList.remove('opacity-100', 'scale-100');
          card.classList.add('opacity-0', 'scale-95');
        }
        if (overlay) {
          overlay.classList.remove('opacity-100');
          overlay.classList.add('opacity-0');
        }
        setTimeout(function () {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          document.body.style.overflow = '';
          contentEl.innerHTML = '';
        }, 200);
      }

      function getHashSlug() {
        const h = location.hash.replace(/^#/, '');
        if (h.indexOf(PREFIX) === 0) return h.slice(PREFIX.length);
        return '';
      }

      // Card click → hash
      document.addEventListener('click', function (e) {
        const clickedCard = e.target.closest('[data-adopter-id]');
        if (clickedCard) {
          const id = clickedCard.getAttribute('data-adopter-id');
          if (id) {
            e.preventDefault();
            location.hash = PREFIX + id;
          }
        }
      });

      // Close buttons + overlay
      if (modal) {
        modal.addEventListener('click', function (e) {
          if (e.target.hasAttribute('data-modal-close') || e.target.closest('[data-modal-close]')) {
            closeModal();
            history.replaceState(null, '', location.pathname + location.search);
          }
        });
      }

      // ESC
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && getHashSlug()) {
          closeModal();
          history.replaceState(null, '', location.pathname + location.search);
        }
      });

      // Hash change
      function syncHash() {
        const slug = getHashSlug();
        if (slug) {
          openModal(slug);
        } else if (modal && !modal.classList.contains('hidden')) {
          closeModal();
        }
      }
      window.addEventListener('hashchange', syncHash);

      // Language change → rebuild modal content if open
      document.addEventListener('languagechange', function () {
        const slug = getHashSlug();
        if (slug && !modal.classList.contains('hidden')) {
          openModal(slug);
        }
      });

      // Initial check
      if (getHashSlug()) {
        syncHash();
      }
    })();
  </script>
</Layout>

<style is:global>
  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .marquee-left {
    animation: marquee-left 60s linear infinite;
    will-change: transform;
  }

  .marquee-left:hover {
    animation-play-state: paused;
  }

  .marquee-right {
    animation: marquee-right 60s linear infinite;
    will-change: transform;
  }

  .marquee-right:hover {
    animation-play-state: paused;
  }
</style>
