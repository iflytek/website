---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('project');
  return projects.map((project) => ({
    params: { slug: project.id.replace('.yaml', '').replace('.yml', '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const metadata = {
  title: data.name,
  description: data.description,
};

const langColors: Record<string, string> = {
  Java: '#b07219',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  JavaScript: '#f1e05a',
  Go: '#00ADD8',
  Shell: '#89e051',
};

const categoryLabels: Record<string, string> = {
  'ai-platform': 'AI 平台 / AI Platform',
  'developer-tools': '开发者工具 / Developer Tools',
  'rpa-automation': 'RPA & 自动化 / RPA & Automation',
  'ai-skills': 'AI 技能 / AI Skills',
  tutorials: '教程 / Tutorials',
  'nlp-speech': 'NLP & 语音 / NLP & Speech',
  infrastructure: '基础设施 / Infrastructure',
};
---

<Layout metadata={metadata}>
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <a href="/projects" class="hover:text-primary-600 dark:hover:text-primary-400">项目</a>
        <span>/</span>
        <span class="text-gray-900 dark:text-white">{data.name}</span>
      </nav>

      <!-- Project Header -->
      <div class="rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-900 md:p-12">
        <div class="flex flex-col gap-6 md:flex-row md:items-start">
          <!-- Icon -->
          <div
            class="flex h-20 w-20 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-purple-600 text-3xl font-bold text-white"
          >
            {data.name.charAt(0)}
          </div>

          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3">
              <h1 class="text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">{data.name}</h1>
              <span
                class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400"
              >
                {categoryLabels[data.category] || data.category}
              </span>
            </div>

            <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
              {data.description}
            </p>
            {data.descriptionEn && <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">{data.descriptionEn}</p>}
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
          <div class="rounded-xl bg-gray-50 p-4 text-center dark:bg-gray-800">
            <div class="text-2xl font-bold text-yellow-600">{(data.stars || 0).toLocaleString()}</div>
            <div class="mt-1 text-xs text-gray-500">Stars</div>
          </div>
          <div class="rounded-xl bg-gray-50 p-4 text-center dark:bg-gray-800">
            <div class="text-2xl font-bold text-blue-600">{(data.forks || 0).toLocaleString()}</div>
            <div class="mt-1 text-xs text-gray-500">Forks</div>
          </div>
          <div class="rounded-xl bg-gray-50 p-4 text-center dark:bg-gray-800">
            <div class="text-2xl font-bold text-green-600">{data.license || 'N/A'}</div>
            <div class="mt-1 text-xs text-gray-500">License</div>
          </div>
          <div class="rounded-xl bg-gray-50 p-4 text-center dark:bg-gray-800">
            <div class="flex flex-wrap items-center justify-center gap-1">
              {
                data.languages?.map((lang) => (
                  <span class="flex items-center gap-1 text-sm font-semibold">
                    <span
                      class="inline-block h-3 w-3 rounded-full"
                      style={`background-color: ${langColors[lang] || '#999'}`}
                    />
                    {lang}
                  </span>
                ))
              }
            </div>
            <div class="mt-1 text-xs text-gray-500">Languages</div>
          </div>
        </div>

        <!-- Tags -->
        {
          data.tags && data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {data.tags.map((tag) => (
                <span class="rounded-lg bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700 dark:bg-primary-950 dark:text-primary-300">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }

        <!-- Action Buttons -->
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={`https://github.com/${data.repo}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-3 font-medium text-white transition-colors hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-200"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
            查看源码 / View Source
          </a>
          {
            data.homepage && (
              <a
                href={data.homepage}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 rounded-xl bg-primary-600 px-6 py-3 font-medium text-white transition-colors hover:bg-primary-700"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
                访问官网 / Visit Website
              </a>
            )
          }
        </div>
      </div>

      <!-- Back to Projects -->
      <div class="mt-8 text-center">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-gray-600 transition-colors hover:text-primary-600 dark:text-gray-400 dark:hover:text-primary-400"
        >
          ← 返回项目列表 / Back to Projects
        </a>
      </div>
    </div>
  </section>
</Layout>
