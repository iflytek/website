---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Landscape',
};

const projects = await getCollection('project');

// Group by category
const grouped = projects.reduce(
  (acc, p) => {
    const cat = p.data.category;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(p);
    return acc;
  },
  {} as Record<string, typeof projects>
);

const categoryInfo: Record<
  string,
  { label: string; labelEn: string; description: string; color: string; icon: string }
> = {
  'ai-platform': {
    label: 'AI 平台',
    labelEn: 'AI Platform',
    description: 'AI 大模型、Agent 工作流编排与智能自动化平台',
    color: 'from-blue-500 to-blue-600',
    icon: '🤖',
  },
  'developer-tools': {
    label: '开发者工具',
    labelEn: 'Developer Tools',
    description: 'SDK、技能注册中心、IDE 插件等开发者效率工具',
    color: 'from-green-500 to-green-600',
    icon: '🛠️',
  },
  'nlp-speech': {
    label: 'NLP & 语音',
    labelEn: 'NLP & Speech',
    description: '自然语言处理、语音识别与合成引擎',
    color: 'from-purple-500 to-purple-600',
    icon: '🗣️',
  },
  infrastructure: {
    label: '基础设施',
    labelEn: 'Infrastructure',
    description: '模型服务框架、数据处理与部署工具',
    color: 'from-orange-500 to-orange-600',
    icon: '⚙️',
  },
};

const totalStars = projects.reduce((sum, p) => sum + (p.data.stars || 0), 0);
---

<Layout metadata={metadata}>
  <!-- Header -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-gray-50 to-white py-16 dark:from-gray-900 dark:to-gray-950 md:py-20"
  >
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_40%,rgba(0,102,255,0.08),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_60%,rgba(0,212,170,0.08),transparent_50%)]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
          <span class="bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent">
            开源全景图
          </span>
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          iFLYTEK 开源项目生态全景 — {projects.length} 个项目，{totalStars.toLocaleString()} Stars
        </p>
      </div>
    </div>
  </section>

  <!-- Landscape Map -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Category Sections -->
      <div class="space-y-12">
        {
          Object.entries(categoryInfo).map(([catKey, info]) => {
            const catProjects = grouped[catKey] || [];
            if (catProjects.length === 0) return null;
            return (
              <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-900">
                {/* Category Header */}
                <div class={`bg-gradient-to-r ${info.color} px-6 py-4`}>
                  <div class="flex items-center gap-3">
                    <span class="text-2xl">{info.icon}</span>
                    <div>
                      <h2 class="text-xl font-bold text-white">
                        {info.label} / {info.labelEn}
                      </h2>
                      <p class="text-sm text-white/80">{info.description}</p>
                    </div>
                    <span class="ml-auto rounded-full bg-white/20 px-3 py-1 text-sm font-medium text-white">
                      {catProjects.length} projects
                    </span>
                  </div>
                </div>

                {/* Project Grid */}
                <div class="p-6">
                  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    {catProjects.map((project) => (
                      <a
                        href={`https://github.com/${project.data.repo}`}
                        target="_blank"
                        rel="noopener"
                        class="group flex items-start gap-3 rounded-xl border border-gray-100 p-4 transition-all hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-md dark:border-gray-800 dark:hover:border-primary-800"
                      >
                        {/* Project Icon */}
                        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-accent-500 text-sm font-bold text-white">
                          {project.data.name.charAt(0)}
                        </div>

                        <div class="min-w-0 flex-1">
                          <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                            {project.data.name}
                          </h3>
                          <p class="mt-1 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">
                            {project.data.description}
                          </p>

                          {/* Stats */}
                          <div class="mt-2 flex items-center gap-3 text-xs text-gray-400">
                            <span class="flex items-center gap-1">
                              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                              </svg>
                              {(project.data.stars || 0).toLocaleString()}
                            </span>
                            <span class="flex items-center gap-1">
                              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                                <path
                                  fill-rule="evenodd"
                                  d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
                                  clip-rule="evenodd"
                                />
                              </svg>
                              {(project.data.forks || 0).toLocaleString()}
                            </span>
                            {/* Language dots */}
                            {project.data.languages?.slice(0, 2).map((lang) => (
                              <span class="flex items-center gap-1">
                                <span
                                  class="inline-block h-2 w-2 rounded-full"
                                  style={`background-color: ${
                                    lang === 'Java'
                                      ? '#b07219'
                                      : lang === 'TypeScript'
                                        ? '#3178c6'
                                        : lang === 'Python'
                                          ? '#3572A5'
                                          : '#999'
                                  }`}
                                />
                                {lang}
                              </span>
                            ))}
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Empty state for categories with no projects -->
      {
        Object.entries(categoryInfo)
          .filter(([catKey]) => !grouped[catKey] || grouped[catKey].length === 0)
          .map(([, info]) => (
            <div class="mt-8 rounded-xl border border-dashed border-gray-300 p-8 text-center dark:border-gray-700">
              <span class="text-3xl">{info.icon}</span>
              <h3 class="mt-2 font-semibold text-gray-700 dark:text-gray-300">
                {info.label} / {info.labelEn}
              </h3>
              <p class="mt-1 text-sm text-gray-500">即将开放 / Coming Soon</p>
            </div>
          ))
      }

      <!-- Legend / Info -->
      <div class="mt-12 rounded-xl bg-gray-50 p-6 dark:bg-gray-800/50">
        <h3 class="font-semibold text-gray-900 dark:text-white">关于全景图 / About Landscape</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
          全景图以分类视图展示 iFLYTEK 所有开源项目，数据基于 GitHub 仓库实时更新。 灵感来源于 <a
            href="https://landscape.cncf.io"
            target="_blank"
            rel="noopener"
            class="text-primary-600 underline dark:text-primary-400">CNCF Landscape</a
          >。 项目数据每周自动通过 GitHub Actions 更新。
        </p>
      </div>
    </div>
  </section>
</Layout>
