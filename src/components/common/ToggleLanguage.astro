---
export interface Props {
  label?: string;
  class?: string;
}

const { label = 'Language', class: className = '' } = Astro.props;
---

<div
  class:list={['inline-flex items-center rounded-lg bg-gray-100 dark:bg-gray-800 p-1 gap-0.5', className]}
  role="radiogroup"
  aria-label={label}
>
  <button
    type="button"
    class="rounded-md px-2 py-1 text-xs font-medium transition-all duration-200 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 data-[active]:bg-white data-[active]:text-primary data-[active]:shadow-sm dark:data-[active]:bg-gray-600 dark:data-[active]:text-white dark:data-[active]:shadow-md"
    aria-label="中文"
    data-aw-lang-btn="zh"
  >
    中文
  </button>
  <button
    type="button"
    class="rounded-md px-2 py-1 text-xs font-medium transition-all duration-200 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 data-[active]:bg-white data-[active]:text-primary data-[active]:shadow-sm dark:data-[active]:bg-gray-600 dark:data-[active]:text-white dark:data-[active]:shadow-md"
    aria-label="English"
    data-aw-lang-btn="en"
  >
    EN
  </button>
</div>
