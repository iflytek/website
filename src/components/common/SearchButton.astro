---
/**
 * Search trigger button / bar in the header.
 * Desktop: wider bar with icon + placeholder + K shortcut badge.
 * Mobile: compact icon button.
 * Clicking opens the search modal.
 */
---

<button
  id="search-btn"
  type="button"
  class="flex items-center gap-2 rounded-lg border border-gray-300 bg-white/80 px-2.5 py-1.5 text-sm text-gray-400 dark:border-gray-600 dark:bg-gray-800/80 hover:border-gray-400 dark:hover:border-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors w-32 sm:w-44 md:w-56 shrink-0"
  aria-label="Search"
>
  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
  <span class="hidden sm:block truncate text-left">
    <span data-lang-zh="搜索…" data-lang-en="Search…">搜索…</span>
  </span>
  <kbd
    class="hidden sm:ml-auto sm:inline-flex items-center text-[10px] font-mono bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 rounded px-1.5 py-0.5"
  >
    K
  </kbd>
</button>
