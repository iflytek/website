---
interface Props {
  name: string;
  description: string;
  descriptionEn?: string;
  repo: string;
  homepage?: string;
  category: string;
  tags?: string[];
  languages?: string[];
  stars?: number;
  forks?: number;
  license?: string;
  icon?: string;
  links?: string[];
}

const {
  name,
  description,
  descriptionEn,
  repo,
  homepage,
  category,
  tags = [],
  languages = [],
  stars = 0,
  forks = 0,
  license,
  icon,
  links = [],
} = Astro.props;

const categoryColors: Record<string, string> = {
  'agentic-workflow': 'bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-300',
  'agentic-automation': 'bg-teal-100 text-teal-800 dark:bg-teal-900/50 dark:text-teal-300',
  'agent-skills': 'bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300',
  tutorial: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-300',
  'agent-management': 'bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300',
  'agent-engine': 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/50 dark:text-indigo-300',
  'memory-system': 'bg-violet-100 text-violet-800 dark:bg-violet-900/50 dark:text-violet-300',
  llm: 'bg-rose-100 text-rose-800 dark:bg-rose-900/50 dark:text-rose-300',
};

const categoryLabels: Record<string, { zh: string; en: string }> = {
  'agentic-workflow': { zh: '智能体工作流 (agentic-workflow)', en: 'agentic-workflow' },
  'agentic-automation': { zh: '智能体自动化 (agentic-automation)', en: 'agentic-automation' },
  'agent-skills': { zh: '智能体技能 (agent-skills)', en: 'agent-skills' },
  tutorial: { zh: '教程指南 (tutorial)', en: 'tutorial' },
  'agent-management': { zh: '智能体管理 (agent-management)', en: 'agent-management' },
  'agent-engine': { zh: '智能体引擎 (agent-engine)', en: 'agent-engine' },
  'memory-system': { zh: '记忆系统 (memory-system)', en: 'memory-system' },
  llm: { zh: '大语言模型 (LLM)', en: 'LLM' },
};

const langColors: Record<string, string> = {
  Java: '#b07219',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  JavaScript: '#f1e05a',
  Go: '#00ADD8',
  Shell: '#89e051',
};

function formatNumber(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return n.toString();
}
---

<div
  class:list={[
    'group relative flex h-full flex-col rounded-xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-900',
  ]}
>
  <!-- Header -->
  <div class="flex items-start gap-4">
    <!-- Project Icon -->
    <div
      class:list={[
        'flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-xl overflow-hidden',
        icon ? '' : 'bg-gradient-to-br from-gradient-start to-gradient-end text-xl font-bold text-white',
      ]}
    >
      {icon ? <img src={icon} alt={name} class="h-full w-full object-contain" loading="lazy" /> : name.charAt(0)}
    </div>

    <div class="min-w-0 flex-1">
      <h3 class="text-lg font-bold text-gray-900 dark:text-white">
        <a
          href={homepage || `https://github.com/${repo}`}
          class="hover:text-primary-600 dark:hover:text-primary-400"
          target="_blank"
          rel="noopener"
        >
          {name}
        </a>
      </h3>
      <!-- Category tag -->
      <span
        class:list={[
          'mt-1 inline-block rounded-full px-2.5 py-0.5 text-xs font-medium',
          categoryColors[category] || 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300',
        ]}
      >
        {
          categoryLabels[category] ? (
            <span data-lang-zh={categoryLabels[category].zh} data-lang-en={categoryLabels[category].en}>
              {categoryLabels[category].zh}
            </span>
          ) : (
            category
          )
        }
      </span>
    </div>
  </div>

  <!-- Description -->
  <p class="mt-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
    {
      descriptionEn ? (
        <span data-lang-zh={description} data-lang-en={descriptionEn}>
          {description}
        </span>
      ) : (
        description
      )
    }
  </p>

  <!-- Languages -->
  {
    languages.length > 0 && (
      <div class="mt-4 flex flex-wrap items-center gap-2">
        {languages.map((lang) => (
          <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
            <span class="inline-block h-3 w-3 rounded-full" style={`background-color: ${langColors[lang] || '#999'}`} />
            {lang}
          </span>
        ))}
      </div>
    )
  }

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag) => (
          <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">
            {tag}
          </span>
        ))}
        {tags.length > 4 && (
          <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800 dark:text-gray-500">
            +{tags.length - 4}
          </span>
        )}
      </div>
    )
  }

  <!-- Footer: Stats + Links -->
  <div
    class="mt-5 flex flex-col gap-3 border-t border-gray-100 pt-4 sm:flex-row sm:items-center sm:justify-between dark:border-gray-800"
  >
    <!-- GitHub Stats -->
    <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
      <a
        href={`https://github.com/${repo}/stargazers`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1 transition-colors hover:text-yellow-600"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"
          ><path
            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
          ></path></svg
        >
        {formatNumber(stars)}
      </a>
      <a
        href={`https://github.com/${repo}/network/members`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1 transition-colors hover:text-blue-600"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"
          ><path
            fill-rule="evenodd"
            d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
            clip-rule="evenodd"></path></svg
        >
        {formatNumber(forks)}
      </a>
      {
        license && (
          <span class="inline-flex items-center gap-1">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              />
            </svg>
            {license}
          </span>
        )
      }
    </div>

    <!-- Links + GitHub Button -->
    <div class="inline-flex flex-wrap items-center gap-2">
      {
        links.map((link) => {
          const isHF = link.includes('huggingface');
          const isMS = link.includes('modelscope');
          const label = isHF ? 'Hugging Face' : isMS ? 'ModelScope' : 'Link';
          return (
            <a
              href={link}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-lg bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
            >
              {isHF ? (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z" />
                  <circle cx="9" cy="10" r="1.2" />
                  <circle cx="15" cy="10" r="1.2" />
                  <path
                    d="M8.5 13.5s1.5 2 3.5 2 3.5-2 3.5-2"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    stroke-linecap="round"
                  />
                </svg>
              ) : isMS ? (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10" />
                  <circle cx="12" cy="12" r="6" />
                  <circle cx="12" cy="12" r="2" />
                </svg>
              ) : (
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              )}
              {label}
            </a>
          );
        })
      }
      <!-- GitHub Link -->
      <a
        href={`https://github.com/${repo}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 rounded-lg bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path></svg
        >
        GitHub
      </a>
    </div>
  </div>
</div>
