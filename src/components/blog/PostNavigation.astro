---
import type { Post } from '~/types';

export interface Props {
  prev?: Post;
  next?: Post;
}

const { prev, next } = Astro.props;
---

<div class="mx-auto px-6 sm:px-6 max-w-6xl pt-8 md:pt-4 pb-12 md:pb-20">
  <div class="flex justify-between gap-4">
    {
      prev ? (
        <a
          href={'/' + prev.permalink}
          class="group flex-1 block p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-blue-400 transition-colors"
        >
          <span class="text-xs text-gray-400 dark:text-gray-500">← 上一篇</span>
          <p class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-blue-400 transition-colors line-clamp-2">
            {prev.title}
          </p>
        </a>
      ) : (
        <div class="flex-1" />
      )
    }
    {
      next ? (
        <a
          href={'/' + next.permalink}
          class="group flex-1 block p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-blue-400 transition-colors text-right"
        >
          <span class="text-xs text-gray-400 dark:text-gray-500">下一篇 →</span>
          <p class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-blue-400 transition-colors line-clamp-2">
            {next.title}
          </p>
        </a>
      ) : (
        <div class="flex-1" />
      )
    }
  </div>
</div>
