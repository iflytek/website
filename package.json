{
  "name": "@iflytek/website",
  "version": "0.4.0",
  "description": "iFLYTEK Open Source Website - Showcasing open source projects, blog, events and community contributions.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run prebuild && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prebuild": "tsx scripts/fetch-community-files.ts && tsx scripts/fetch-project-stats.ts && tsx scripts/watermark-images.ts",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "fetch:contributors": "tsx scripts/fetch-contributors.ts",
    "fetch:project-stats": "tsx scripts/fetch-project-stats.ts",
    "license:check": "license-checker --production --excludePrivatePackages --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;Unlicense;BlueOak-1.0.0;OFL-1.1;MPL-2.0;LGPL-3.0-or-later;Python-2.0'",
    "license:report": "license-checker --production --markdown --out THIRD_PARTY_LICENSES.md",
    "license:summary": "license-checker --production --summary"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/inter": "^5.3.0",
    "astro": "^6.4.8",
    "astro-embed": "^0.13.1",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "fuse.js": "^7.5.0",
    "html-to-image": "^1.11.13",
    "limax": "4.2.3",
    "lodash.merge": "^4.6.2",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/partytown": "^2.1.7",
    "@eslint/js": "^10.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.36",
    "@octokit/rest": "^21.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "astro-compress": "^2.4.1",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "js-yaml": "^4.3.0",
    "license-checker": "^25.0.1",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "vite": "^7",
    "esbuild": ">=0.28.1",
    "path-to-regexp": ">=6.3.0"
  }
}
